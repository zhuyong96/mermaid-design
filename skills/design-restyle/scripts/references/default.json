{
  "_meta": {
    "description": "Reference design system presets for semantic restyling",
    "version": "1.0.0",
    "usage": "Load with semantic-mapper.py --reference <key>"
  },

  "tailwind": {
    "name": "Tailwind CSS Default",
    "description": "Tailwind's default design tokens. Universal, reliable, widely adopted.",
    "info": "https://tailwindcss.com/docs/configuration",
    "css": {
      "colors": {
        "primary": "#3b82f6",
        "primary-hover": "#2563eb",
        "primary-active": "#1d4ed8",
        "primary-light": "#93c5fd",
        "primary-bg": "#eff6ff",
        "success": "#22c55e",
        "success-bg": "#f0fdf4",
        "warning": "#f59e0b",
        "warning-bg": "#fffbeb",
        "danger": "#ef4444",
        "danger-bg": "#fef2f2",
        "info": "#06b6d4",
        "info-bg": "#ecfeff",
        "text-primary": "#111827",
        "text-secondary": "#6b7280",
        "text-tertiary": "#9ca3af",
        "text-disabled": "#d1d5db",
        "text-inverse": "#ffffff",
        "text-link": "#3b82f6",
        "bg-page": "#f9fafb",
        "bg-card": "#ffffff",
        "bg-surface": "#f3f4f6",
        "bg-elevated": "#ffffff",
        "bg-hover": "#f9fafb",
        "bg-active": "#f3f4f6",
        "bg-modal-overlay": "rgba(0, 0, 0, 0.5)",
        "border-default": "#e5e7eb",
        "border-hover": "#d1d5db",
        "border-focus": "#3b82f6",
        "border-light": "#f3f4f6"
      },
      "spacing": {
        "grid": 4,
        "xs": "4px",
        "sm": "8px",
        "md": "16px",
        "lg": "24px",
        "xl": "32px",
        "2xl": "40px",
        "3xl": "48px"
      },
      "typography": {
        "font-family": "'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "font-mono": "'JetBrains Mono', 'Fira Code', 'SF Mono', ui-monospace, monospace",
        "font-size-xs": "12px",
        "font-size-sm": "14px",
        "font-size-base": "16px",
        "font-size-lg": "18px",
        "font-size-xl": "20px",
        "font-size-2xl": "24px",
        "font-size-3xl": "30px",
        "font-weight-normal": "400",
        "font-weight-medium": "500",
        "font-weight-semibold": "600",
        "font-weight-bold": "700",
        "line-height-tight": "1.25",
        "line-height-normal": "1.5",
        "line-height-relaxed": "1.75"
      },
      "radius": {
        "none": "0px",
        "sm": "4px",
        "md": "6px",
        "lg": "8px",
        "xl": "12px",
        "2xl": "16px",
        "full": "9999px"
      },
      "shadow": {
        "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
        "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
        "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
        "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
        "none": "0 0 #0000"
      }
    }
  },

